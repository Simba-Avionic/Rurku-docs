# ==========================================
# IDE & Edytory (VS Code & devcontainer)
# ==========================================

# VS Code
# Ignorujemy całą ścieżkę .vscode prócz plików konfiguracyjnych, które warto współdzielić
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Devcontainers
# Domyślnie devcontainer powinieneś trzymać w repozytorium!
# Ignorujemy tylko lokalne nadpisania i dane tymczasowe:
.devcontainer/*.local.*
.devcontainer/docker-compose.override.yml

